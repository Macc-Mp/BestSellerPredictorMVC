@model IndexViewModel

<div class="row">
    <div class="col-md-6">
        <h4>Step 1 — Upload Training Excel</h4>
        <form asp-action="UploadTrainingExcel" asp-controller="Home" enctype="multipart/form-data" method="post">
            <div class="form-group">
                <label for="trainingExcelFile">Training Excel (.xlsx):</label>
                <input type="file" name="trainingExcelFile" id="trainingExcelFile" class="form-control" accept=".xlsx" required />
            </div>
            <button type="submit" class="btn btn-primary mt-2">Upload & Train</button>
        </form>

        @if (TempData["TrainingExcelUploaded"] as bool? == true)
        {
            <div class="alert alert-success mt-2">Training file uploaded for your session. The model is being trained.</div>
        }
    </div>

    <div class="col-md-6">
        <h4>Step 2 — Upload Prediction Excel</h4>

        @if (ViewBag.ModelTrained as bool? == true)
        {
            <form asp-action="UploadPredictionExcel" asp-controller="Home" enctype="multipart/form-data" method="post">
                <div class="form-group">
                    <label for="predictionExcelFile">Prediction Excel (.xlsx):</label>
                    <input type="file" name="predictionExcelFile" id="predictionExcelFile" class="form-control" accept=".xlsx" required />
                </div>
                <button type="submit" class="btn btn-primary mt-2">Upload & Predict</button>
            </form>

            @if (TempData["PredictionExcelUploaded"] as bool? == true)
            {
                <div class="alert alert-success mt-2">Prediction file uploaded for your session.</div>
            }
        }
        else
        {
            <div class="alert alert-info">
                The model is not trained for your session yet. Upload a training file (left) to proceed.
            </div>
        }
    </div>
</div>

<hr />

@if (ViewBag.TrainingExcelUploaded as bool? == true && Model?.TrainingDataList?.Count > 0)
{
    <h5>Training Data (from your uploaded Excel)</h5>
    <table class="table">
        <thead>
            <tr>
                <th>PID</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Unit Price</th>
                <th>Quantity Sold</th>
                <th>Sale Performance Category</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.TrainingDataList)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.ProductName</td>
                    <td>@item.Category</td>
                    <td>@item.UnitPrice</td>
                    <td>@item.QuantitySold</td>
                    <td>@item.SalePerformanceCategory</td>
                </tr>
            }
        </tbody>
    </table>
}

@if ((ViewBag.TrainingExcelUploaded as bool? == true) && (ViewBag.ModelTrained as bool? == true))
{
    <h5>Model Evaluation Metrics (your session)</h5>
    <ul>
        <li>MicroAccuracy: @ViewBag.ModelMetric_Micro</li>
        <li>MacroAccuracy: @ViewBag.ModelMetric_Macro</li>
        <li>LogLoss: @ViewBag.ModelMetric_LogLoss</li>
    </ul>
}

@if ((ViewBag.PredictionExcelUploaded as bool? == true) && (ViewBag.ModelTrained as bool? == true) && Model?.PredictionResults?.Count > 0)
{
    <h5>Predicted Sale Performance (for your uploaded prediction file)</h5>
    <table class="table">
        <thead>
            <tr>
                <th>Product ID</th>
                <th>Predicted Category</th>
                <th>Scores</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.PredictionResults.Count; i++)
            {
                var pred = Model.PredictionResults[i];
                <tr>
                    <td>@Model.ProductList[i].ProductId</td>
                    <td>@pred.PredictedSalePerformanceCategory</td>
                    <td>
                        @if (pred.Score != null)
                        {
                            for (int j = 0; j < pred.Score.Length; j++)
                            {
                                <div>@pred.Score[j].ToString("F4")</div>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
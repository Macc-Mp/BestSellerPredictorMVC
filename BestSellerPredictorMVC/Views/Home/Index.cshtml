@model IndexViewModel

@{
    // Fix: Access session via ViewContext.HttpContext in Razor views
    var trainingFile = ViewContext.HttpContext.Session.GetString("TrainingFile") ?? "—";
    var predictionFile = ViewContext.HttpContext.Session.GetString("PredictionFile") ?? "—";
}

<div class="row">
      <h3>Excel File (.Xlsx) Required Columns</h3>
        <ul class="Pre">
            <li>ProductID (txt)</li>
            <li>ProductName (txt)</li>
            <li>Category (txt)</li>
            <li>UnitPrice (#)</li>
            <li>QuantitySold (#)</li>
            <li>SalePerformanceCategory (txt)</li>
        </ul>
</<div>
    <div class="col-md-6">
        <h4>Step 1 — Upload Training Excel</h4>
        <form asp-action="UploadTrainingExcel" asp-controller="Home" enctype="multipart/form-data" method="post">
            <div class="form-group">
                <label for="trainingExcelFile">Training Excel (.xlsx):</label>
                <input type="file" name="trainingExcelFile" id="trainingExcelFile" class="form-control" accept=".xlsx" required />
            </div>
            <button type="submit" class="btn btn-primary mt-2">Upload & Train</button>
        </form>

        @if (TempData["TrainingExcelUploaded"] as bool? == true)
        {
            <div class="alert alert-success mt-2">Training file uploaded for your session. The model is being trained.</div>
        }

        @if (TempData["TrainingError"] != null)
        {
            <div class="alert alert-danger mt-2">@TempData["TrainingError"]</div>
        }
    </div>

    <div class="col-md-6">
        <h4>Step 2 — Upload Prediction Excel</h4>

        @* Enable Step 2 if:
            - model is already trained (ViewBag or TempData), OR
            - a training file was just uploaded (TempData["TrainingExcelUploaded"]) so user can upload a prediction while training runs.
           If only TrainingExcelUploaded is present, show a small note so user knows training may still be in progress. *@
        @{
            var modelReady = (TempData["ModelTrained"] as bool? == true) || (ViewBag.ModelTrained as bool? == true);
            var trainingUploaded = (TempData["TrainingExcelUploaded"] as bool? == true);
        }

        @if (modelReady || trainingUploaded)
        {
            <form asp-action="UploadPredictionExcel" asp-controller="Home" enctype="multipart/form-data" method="post">
                <div class="form-group">
                    <label for="predictionExcelFile">Prediction Excel (.xlsx):</label>
                    <input type="file" name="predictionExcelFile" id="predictionExcelFile" class="form-control" accept=".xlsx" required />
                </div>
                <button type="submit" class="btn btn-primary mt-2">Upload & Predict</button>
            </form>

            @if (trainingUploaded && !modelReady)
            {
                <div class="alert alert-warning mt-2">
                    Model training is in progress. You may upload a prediction file now — it will be processed once training completes for your session.
                </div>
            }

            @if (TempData["PredictionExcelUploaded"] as bool? == true)
            {
                <div class="alert alert-success mt-2">Prediction file uploaded for your session.</div>
            }
        }
        else
        {
            <div class="alert alert-info">
                The model is not trained for your session yet. Upload a training file (left) to proceed.
            </div>
        }
    </div>
</div>

<hr />

@if (ViewBag.TrainingExcelUploaded as bool? == true && Model?.TrainingDataList?.Count > 0)
{
    <h5>Training Data (from your uploaded Excel)</h5>
    <table class="table">
        <thead>
            <tr>
                <th>ProductID</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Unit Price</th>
                <th>Quantity Sold</th>
                <th>Sale Performance Category</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.TrainingDataList)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.ProductName</td>
                    <td>@item.Category</td>
                    <td>@item.UnitPrice</td>
                    <td>@item.QuantitySold</td>
                    <td>@item.SalePerformanceCategory</td>
                </tr>
            }
        </tbody>
    </table>
}

@if ((ViewBag.TrainingExcelUploaded as bool? == true) && (ViewBag.ModelTrained as bool? == true))
{
    <h5>Model Evaluation Metrics (your session)</h5>
    <ul>
        <li>MicroAccuracy: @ViewBag.ModelMetric_Micro</li>
        <li>MacroAccuracy: @ViewBag.ModelMetric_Macro</li>
        <li>LogLoss: @ViewBag.ModelMetric_LogLoss</li>
    </ul>
}

@if ((ViewBag.PredictionExcelUploaded as bool? == true) && (ViewBag.ModelTrained as bool? == true) && Model?.PredictionResults?.Count > 0)
{
    <h5>Predicted Sale Performance (for your uploaded prediction file)</h5>
    <table class="table">
        <thead>
            <tr>
                <th>Product ID</th>
                <th>Product Name</th>
                <th>Predicted Category</th>
                <th>Scores</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.PredictionResults.Count; i++)
            {
                var pred = Model.PredictionResults[i];
                <tr>
                    <td>@Model.ProductList[i].ProductId</td>
                    <td>@Model.ProductList[i].ProductName</td>
                    <td>@pred.PredictedSalePerformanceCategory</td>
                    <td>
                        @if (pred.Score != null)
                        {
                            for (int j = 0; j < pred.Score.Length; j++)
                            {
                                <div>@pred.Score[j].ToString("F4")</div>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (TempData["ClearResult"] != null)
{
    <div class="alert alert-info" role="alert">@TempData["ClearResult"]</div>
}

@{
    var sessionToken = ViewContext.HttpContext.Session.GetString("ModelToken");
}

@if (!string.IsNullOrEmpty(sessionToken))
{
    <div class="mb-3">
        <form asp-action="ClearModel" method="post" class="d-inline"
              onsubmit="return confirm('Delete this model and associated uploaded files? This cannot be undone.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Clear Model</button>
        </form>
        <span class="ms-3 text-muted">Model token: <strong>@sessionToken</strong></span>
    </div>
}
else if (!string.IsNullOrEmpty(ViewBag.ModelToken as string))
{
    <div class="mb-3">
        <span class="text-muted">A model exists on the server (token: <strong>@ViewBag.ModelToken</strong>), but it's not associated with your session.</span>
    </div>
}

@if (TempData["ClearFilesResult"] != null)
{
    <div class="alert alert-info mt-2" role="alert">@TempData["ClearFilesResult"]</div>
}

<div class="mb-3">
    <form asp-action="ClearFiles" method="post" class="d-inline"
          onsubmit="return confirm('Delete uploaded training and prediction files for this session? This cannot be undone.');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-warning">Clear Files</button>
    </form>

    @* Show which files would be cleared (session values) *@
    <span class="ms-3 text-muted">
        Training file: <strong>@trainingFile</strong>
        &nbsp;|&nbsp;
        Prediction file: <strong>@predictionFile</strong>
    </span>
</div>

@if (TempData["PredictionPending"] != null)
{
    <div class="alert alert-warning mt-2">@TempData["PredictionPending"]</div>
}

@if (TempData["PredictionError"] != null)
{
    <div class="alert alert-danger mt-2">@TempData["PredictionError"]</div>
}

<input type="hidden" name="token" value="@(ViewBag.ModelToken ?? String.Empty)" />